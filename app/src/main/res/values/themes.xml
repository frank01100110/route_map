<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.RouteMap" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="colorPrimary">@color/route_orange</item>
        <item name="colorSecondary">@color/route_orange_dark</item>
        <item name="android:navigationBarColor">@color/cream</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Widget.RouteMap.PrimaryButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/route_orange</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">28dp</item>
    </style>

    <style name="Widget.RouteMap.SecondaryButton" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/cream</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/route_orange_dark</item>
        <item name="cornerRadius">24dp</item>
    </style>
</resources>
